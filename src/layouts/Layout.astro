---
import "../styles/global.css";

export interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title, 
	description = "Portfolio and blog of Andrés Cruz Chipol, passionate about artificial intelligence, data science, and software development.",
	image = "/profile.webp"
} = Astro.props;

const siteName = "Andrés Cruz Chipol";
const twitterHandle = "@reschip";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  
  <!-- SEO Meta Tags -->
  <title>{`${title} | ${siteName}`}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="Artificial Intelligence, Data Science, Machine Learning, Python, Blog, Portfolio, Andres Cruz Chipol" />
  <meta name="author" content="Andrés Cruz Chipol" />

  <!-- Open Graph (for social media like Facebook) -->
  <meta property="og:title" content={`${title} | ${siteName}`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.url)} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:type" content="website" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content={twitterHandle} />
  <meta name="twitter:creator" content={twitterHandle} />
  <meta name="twitter:title" content={`${title} | ${siteName}`} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.url)} />

  <link rel="icon" type="image/webp" href="/profile.webp" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Aleo:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
</head>
<body>
  <canvas id="game-of-life-canvas"></canvas>
  <div class="wrapper">
    <main class="container">
      <slot />
    </main>
  </div>
  <footer class="bg-[#f42c04] mt-14 h-14 flex flex-col justify-center items-center font-extralight">
    <a href="https://www.andreschipol.com" class="no-underline text-white" >
      www.andreschipol.com
    </a>
  </footer>
</body>
</html>

<style>
  * {
    box-sizing: border-box;
  }

  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    font-family: Arial, sans-serif;
    color: #0f1a20;
    scroll-behavior: smooth;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  #game-of-life-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.4;
    filter: blur(0.5px);
  }

  .wrapper {
    width: 100%;
    padding: 0 1rem; /* Espaciado en móviles */
  }
  
  .container {
    max-width: 800px; /* Ancho máximo del contenedor */
    margin: 0 auto; /* Centrado horizontal */
    padding: 2rem 0;
    width: 100%;
    overflow-x: hidden; /* Evita que el contenido se salga horizontalmente */
    font-family:Aleo;
  }

  @media (max-width: 768px) {
    .wrapper {
      padding: 0 0.5rem;
    }
    
    .container {
      padding: 1rem 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const canvas = document.getElementById('game-of-life-canvas');
    if (!canvas) return;
    const ctx = canvas.getContext('2d');

    let cellSize = 12;
    let speed = 800;
    const specialColors = ['#8B93FF', '#40E0A4', '#FF8B8B'];

    let grid;
    let cellColors;
    let columns;
    let rows;

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      initGame();
    }

    function initGame() {
      columns = Math.ceil(canvas.width / cellSize);
      rows = Math.ceil(canvas.height / cellSize);

      grid = Array(columns)
        .fill(null)
        .map(() =>
          Array(rows)
            .fill(null)
            .map(() => Math.random() > 0.85)
        );
      cellColors = Array(columns)
        .fill(null)
        .map(() => Array(rows).fill(null));

      draw();
    }

    function update() {
      const nextGrid = Array(columns)
        .fill(null)
        .map(() => Array(rows).fill(false));
      const nextColors = Array(columns)
        .fill(null)
        .map(() => Array(rows).fill(null));

      for (let x = 0; x < columns; x++) {
        for (let y = 0; y < rows; y++) {
          const state = grid[x][y];
          let neighbors = 0;

          for (let i = -1; i <= 1; i++) {
            for (let j = -1; j <= 1; j++) {
              if (i === 0 && j === 0) continue;
              const xi = (x + i + columns) % columns;
              const yj = (y + j + rows) % rows;
              if (grid[xi][yj]) neighbors++;
            }
          }

          if (state && (neighbors < 2 || neighbors > 3)) {
            nextGrid[x][y] = false;
          } else if (!state && neighbors === 3) {
            nextGrid[x][y] = true;
          } else {
            nextGrid[x][y] = state;
            if (state) {
              nextColors[x][y] = cellColors[x][y];
            }
          }

          if (nextGrid[x][y] && Math.random() < 0.03) {
            if (Math.random() < 0.08) {
              const colorIndex = Math.floor(Math.random() * specialColors.length);
              nextColors[x][y] = specialColors[colorIndex];
            } else {
              nextColors[x][y] = null;
            }
          }
        }
      }

      grid = nextGrid;
      cellColors = nextColors;
    }

    function draw() {
      ctx.fillStyle = '#f0eee6';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      for (let x = 0; x < columns; x++) {
        for (let y = 0; y < rows; y++) {
          if (grid[x][y]) {
            ctx.fillStyle = cellColors[x][y] || '#D4D2C8';
            ctx.beginPath();
            ctx.roundRect(x * cellSize, y * cellSize, cellSize - 1, cellSize - 1, 2);
            ctx.fill();
          }
        }
      }
    }

    function gameLoop() {
      update();
      draw();
      setTimeout(gameLoop, speed);
    }

    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();
    gameLoop();
  });
</script>
