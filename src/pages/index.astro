---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import profileImage from '../assets/images/profile.webp';
import hfLogo from '../assets/images/hf-logo.svg';
import layer7Logo from '../assets/images/layer7_mx_logo.jpeg';
import hospitalAngeles from '../assets/images/9b31d507dd2bb615fb4a9a066087caac.jpeg';
import buapLogo from '../assets/images/imagen_base_slider.png';
import cimatLogo from '../assets/images/q-CnogwU_400x400.jpg';
import langchainLogo from '../assets/images/langchain-color.png';
import langgraphLogo from '../assets/images/langgraph-color.png';
---

<Layout
  title="Home"
  description="Portfolio and blog of Andrés Cruz Chipol, passionate about artificial intelligence, data science, and software development."
>

  <!-- ══════════════════════════════════════════════════════════
       HERO  — split layout: left panel / right = 3D canvas
  ══════════════════════════════════════════════════════════ -->
  <section class="hero">
    <!-- Left: content panel -->
    <div class="hero__panel">
      <Image class="hero__avatar" src={profileImage} alt="Andrés Cruz Chipol" loading="eager" decoding="async" />

      <p class="hero__eyebrow">AI Engineer · Applied AI Research · MSc Computer Science</p>

      <h1 class="hero__name">
        Andres<br/>
        <span class="hero__accent">Cruz Chipol</span>
      </h1>

      <p class="hero__bio">
        Building intelligent systems where theory meets production — from classical ML
        to LLMs, agents, and MLOps pipelines. Currently pursuing a Master's in Computer
        Science at Cinvestav, exploring advanced AI research.
      </p>

      <div class="hero__socials">
        <a href="https://www.linkedin.com/in/andreschipol/" target="_blank" rel="noopener noreferrer" class="social-btn" title="LinkedIn">
          <svg viewBox="0 0 448 512" fill="currentColor"><path d="M416 32H31.9C14.3 32 0 46.5 0 64.3v383.4C0 465.5 14.3 480 31.9 480H416c17.6 0 32-14.5 32-32.3V64.3c0-17.8-14.4-32.3-32-32.3zM135.4 416H69V202.2h66.5V416zm-33.2-243c-21.3 0-38.5-17.3-38.5-38.5S80.9 96 102.2 96c21.2 0 38.5 17.3 38.5 38.5 0 21.3-17.2 38.5-38.5 38.5zm282.1 243h-66.4V312c0-24.8-.5-56.7-34.5-56.7-34.6 0-39.9 27-39.9 54.9V416h-66.4V202.2h63.7v29.2h.9c8.9-16.8 30.6-34.5 62.9-34.5 67.2 0 79.7 44.3 79.7 101.9V416z"/></svg>
        </a>
        <a href="https://github.com/reschip" target="_blank" rel="noopener noreferrer" class="social-btn" title="GitHub">
          <svg viewBox="0 0 496 512" fill="currentColor"><path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3.3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5.3-6.2 2.3zm44.2-1.7c-2.9.7-4.9 2.6-4.6 4.9.3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8z"/></svg>
        </a>
        <a href="https://x.com/reschip" target="_blank" rel="noopener noreferrer" class="social-btn" title="X">
          <svg viewBox="0 0 448 512" fill="currentColor"><path d="M64 32C28.7 32 0 60.7 0 96V416c0 35.3 28.7 64 64 64H384c35.3 0 64-28.7 64-64V96c0-35.3-28.7-64-64-64H64zm297.1 84L257.3 234.6 379.4 396H283.8L209 298.1 123.3 396H75.8l111-126.9L69.7 116h98l67.7 89.5L313.6 116h47.5zM323.3 367.6L153.4 142.9H125.1L296.9 367.6h26.3z"/></svg>
        </a>
        <a href="https://www.kaggle.com/andreschipol" target="_blank" rel="noopener noreferrer" class="social-btn" title="Kaggle">
          <svg viewBox="0 0 320 512" fill="currentColor"><path d="M304.2 501.5L158.4 320.3 298.2 185c2.6-2.7 1.7-10.5-5.3-10.5h-69.2c-3.5 0-7 1.8-10.5 5.3L80.9 313.5V7.5q0-7.5-7.5-7.5H21.5Q14 0 14 7.5v497q0 7.5 7.5 7.5h51.9q7.5 0 7.5-7.5v-109l30.8-29.3 110.5 140.6c3 3.5 6.5 5.3 10.5 5.3h66.9q5.3 0 6-3z"/></svg>
        </a>
        <a href="https://huggingface.co/reschip" target="_blank" rel="noopener noreferrer" class="social-btn" title="Hugging Face">
          <Image src={hfLogo} alt="HF" />
        </a>
        <a href="https://computacion.cs.cinvestav.mx/~andres.cruz/" target="_blank" rel="noopener noreferrer" class="social-btn" title="Cinvestav Academic Profile">
          <svg viewBox="0 0 640 512" fill="currentColor"><path d="M320 32c-8.1 0-16.1 1.4-23.7 4.1L15.8 137.4C6.3 140.9 0 149.9 0 160s6.3 19.1 15.8 22.6l57.4 19.1L73.3 388c-1.3 5-1.9 10.2-1.9 15.3 0 26.5 16.3 50.8 41.6 62l185 82.2c13.7 6.1 29.3 6.1 43 0l185-82.2c25.4-11.3 41.6-35.6 41.6-62 0-5.1-.6-10.3-1.9-15.3l.1-.3-14.9-57V174.6l64.6-21.5c9.5-3.5 15.8-12.5 15.8-22.6s-6.3-19.1-15.8-22.6L343.8 36.1C336.2 33.4 328.2 32 320 32zM128 408c0-35.3 86-64 192-64s192 28.7 192 64-86 64-192 64-192-28.7-192-64z"/></svg>
        </a>
      </div>

      <!-- mini legend for the 3D animation -->
      <div class="viz-legend">
        <span class="viz-legend__dot viz-legend__dot--trail"></span>
        <span class="viz-legend__label">Gradient path</span>
        <span class="viz-legend__dot viz-legend__dot--point"></span>
        <span class="viz-legend__label">Current point</span>
      </div>
    </div>

    <!-- Right: the canvas is placed here by CSS (fixed) — this spacer keeps the flow -->
    <div class="hero__canvas-spacer" aria-hidden="true"></div>
  </section>

  <!-- ══════════════════════════════════════════════════════════
       CONTENT AREA — solid cream background, full width
  ══════════════════════════════════════════════════════════ -->
  <div class="content-area">

    <!-- ABOUT -->
    <section class="section reveal" id="about-section">
      <h2 class="section-kicker">About</h2>
      <div class="about-grid">
        <div class="about-bar"></div>
        <div class="about-body">
          <p>I was born in Mexico, in a developing city where the river whispers stories to the sun and oil sleeps beneath cacao trees that dream of rain.</p>
          <p>I traveled where the sea murmurs winds from the Isthmus and ships dance to the rhythm of the sandunga.</p>
          <p>I learned where domes touch the sky amid the scents of talavera and mole, and time walks through alleyways filled with history.</p>
        </div>
      </div>
    </section>

    <!-- EDUCATION -->
    <section class="section section--edu reveal">
      <h2 class="section-kicker">Education</h2>

      <div class="edu-list">

        <!-- MSc — current -->
        <div class="edu-item">
          <div class="edu-badge edu-badge--msc">MSc</div>
          <div class="edu-body">
            <h3 class="edu-degree">Master of Science in Computer Science</h3>
            <span class="edu-field">Artificial Intelligence</span>
            <span class="edu-school">Centro de Investigación y de Estudios Avanzados del IPN — Cinvestav</span>
          </div>
          <div class="edu-meta">
            <span class="edu-years">2025 – 2027</span>
            <span class="edu-status edu-status--active">In Progress</span>
          </div>
        </div>

        <!-- BSc — completed -->
        <div class="edu-item">
          <div class="edu-badge edu-badge--bsc">BSc</div>
          <div class="edu-body">
            <h3 class="edu-degree">Bachelor in Computer Science</h3>
            <span class="edu-field">Computational Science</span>
            <span class="edu-school">Benemérita Universidad Autónoma de Puebla — BUAP</span>
          </div>
          <div class="edu-meta">
            <span class="edu-years">2018 – 2023</span>
            <span class="edu-status edu-status--done">Completed</span>
          </div>
        </div>

      </div>
    </section>

    <!-- WORK EXPERIENCE — CI pipeline style -->
    <section class="section section--pipeline reveal">
      <h2 class="section-kicker">Work Experience</h2>

      <!-- Pipeline header -->
      <div class="pipeline-header" aria-hidden="true">
        <span class="ph-label">job</span>
        <span class="ph-label ph-label--role">role</span>
        <span class="ph-label ph-label--dur">duration</span>
        <span class="ph-label ph-label--status">status</span>
      </div>

      <div class="pipeline-list">

        <!-- 12 months = longest = 100% -->
        <div class="pipe-job" data-hover>
          <div class="pipe-left">
            <span class="pipe-status pipe-status--pass" title="Completed">✓</span>
            <Image class="pipe-logo" src={layer7Logo} alt="Layer7" />
          </div>
          <div class="pipe-body">
            <h3 class="pipe-role">Artificial Intelligence Analyst</h3>
            <span class="pipe-company">Layer7</span>
          </div>
          <div class="pipe-right">
            <div class="pipe-bar-wrap">
              <div class="pipe-bar" style="--fill:100%"></div>
            </div>
            <span class="pipe-range">Aug 2024 – Sep 2025 · 14 mo</span>
          </div>
        </div>

        <!-- 5 months = 42% -->
        <div class="pipe-job" data-hover>
          <div class="pipe-left">
            <span class="pipe-status pipe-status--pass" title="Completed">✓</span>
            <Image class="pipe-logo" src={hospitalAngeles} alt="Hospital Ángeles" />
          </div>
          <div class="pipe-body">
            <h3 class="pipe-role">Data Scientist Internship</h3>
            <span class="pipe-company">Hospital Ángeles</span>
          </div>
          <div class="pipe-right">
            <div class="pipe-bar-wrap">
              <div class="pipe-bar" style="--fill:43%"></div>
            </div>
            <span class="pipe-range">Nov 2022 – Apr 2023 · 6 mo</span>
          </div>
        </div>

        <!-- 2 months = 17% -->
        <div class="pipe-job" data-hover>
          <div class="pipe-left">
            <span class="pipe-status pipe-status--pass" title="Completed">✓</span>
            <Image class="pipe-logo" src={buapLogo} alt="BUAP" />
          </div>
          <div class="pipe-body">
            <h3 class="pipe-role">Research Stay — Machine Learning</h3>
            <span class="pipe-company">BUAP · Benemérita Universidad Autónoma de Puebla</span>
          </div>
          <div class="pipe-right">
            <div class="pipe-bar-wrap">
              <div class="pipe-bar" style="--fill:17%"></div>
            </div>
            <span class="pipe-range">Aug 2021 – Oct 2021 · 2 mo</span>
          </div>
        </div>

        <!-- 2 months = 17% -->
        <div class="pipe-job" data-hover>
          <div class="pipe-left">
            <span class="pipe-status pipe-status--pass" title="Completed">✓</span>
            <Image class="pipe-logo" src={cimatLogo} alt="CIMAT" />
          </div>
          <div class="pipe-body">
            <h3 class="pipe-role">Summer Internship — Data Science</h3>
            <span class="pipe-company">CIMAT · Centro de Investigación en Matemáticas, A.C.</span>
          </div>
          <div class="pipe-right">
            <div class="pipe-bar-wrap">
              <div class="pipe-bar" style="--fill:17%"></div>
            </div>
            <span class="pipe-range">Jun 2021 – Aug 2021 · 2 mo</span>
          </div>
        </div>

      </div>
    </section>



    <!-- TECH STACK — infinite marquee ticker -->
    <section class="section section--stack reveal">
      <h2 class="section-kicker">Stack</h2>
      <p class="section-sub">From model training to production systems.</p>

      <div class="marquee-wrap">

        <!-- Row 1 → scrolls left -->
        <div class="marquee">
          <div class="marquee__track marquee__track--left">
            <!-- Original set -->
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg" alt="Python" loading="lazy" decoding="async">      <span>Python</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/pytorch/pytorch-original.svg" alt="PyTorch" loading="lazy" decoding="async">     <span>PyTorch</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tensorflow/tensorflow-original.svg" alt="TensorFlow" loading="lazy" decoding="async"><span>TensorFlow</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/keras/keras-original.svg" alt="Keras" loading="lazy" decoding="async">       <span>Keras</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/scikitlearn/scikitlearn-original.svg" alt="Scikit" loading="lazy" decoding="async">  <span>Scikit-Learn</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/numpy/numpy-original.svg" alt="NumPy" loading="lazy" decoding="async">       <span>NumPy</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/pandas/pandas-original.svg" alt="Pandas" loading="lazy" decoding="async">      <span>Pandas</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/matplotlib/matplotlib-original.svg" alt="Matplotlib" loading="lazy" decoding="async"><span>Matplotlib</span></div>
            <div class="tech-pill"><Image src={langchainLogo} alt="LangChain" width={20} /><span>LangChain</span></div>
            <div class="tech-pill"><Image src={langgraphLogo} alt="LangGraph" width={20} /><span>LangGraph</span></div>
            <div class="tech-pill"><img src="https://images.chainguard.dev/logos/mlflow.svg" alt="MLflow" loading="lazy" decoding="async">      <span>MLflow</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/fastapi/fastapi-original.svg" alt="FastAPI" loading="lazy" decoding="async">     <span>FastAPI</span></div>
            <!-- Duplicate for seamless loop -->
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/python/python-original.svg" alt="" loading="lazy" decoding="async"><span>Python</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/pytorch/pytorch-original.svg" alt="" loading="lazy" decoding="async"><span>PyTorch</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/tensorflow/tensorflow-original.svg" alt="" loading="lazy" decoding="async"><span>TensorFlow</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/keras/keras-original.svg" alt="" loading="lazy" decoding="async"><span>Keras</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/scikitlearn/scikitlearn-original.svg" alt="" loading="lazy" decoding="async"><span>Scikit-Learn</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/numpy/numpy-original.svg" alt="" loading="lazy" decoding="async"><span>NumPy</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/pandas/pandas-original.svg" alt="" loading="lazy" decoding="async"><span>Pandas</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/matplotlib/matplotlib-original.svg" alt="" loading="lazy" decoding="async"><span>Matplotlib</span></div>
            <div class="tech-pill" aria-hidden="true"><Image src={langchainLogo} alt="" width={20} /><span>LangChain</span></div>
            <div class="tech-pill" aria-hidden="true"><Image src={langgraphLogo} alt="" width={20} /><span>LangGraph</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://images.chainguard.dev/logos/mlflow.svg" alt="" loading="lazy" decoding="async"><span>MLflow</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/fastapi/fastapi-original.svg" alt="" loading="lazy" decoding="async"><span>FastAPI</span></div>
          </div>
        </div>

        <!-- Row 2 → scrolls right -->
        <div class="marquee">
          <div class="marquee__track marquee__track--right">
            <!-- Original set -->
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg" alt="JS" loading="lazy" decoding="async">      <span>JavaScript</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/cplusplus/cplusplus-original.svg" alt="C++" loading="lazy" decoding="async">     <span>C++</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg" alt="Postgres" loading="lazy" decoding="async"><span>PostgreSQL</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg" alt="MySQL" loading="lazy" decoding="async">   <span>MySQL</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg" alt="Docker" loading="lazy" decoding="async">  <span>Docker</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg" alt="Git" loading="lazy" decoding="async">     <span>Git</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/github/github-original.svg" alt="GitHub" loading="lazy" decoding="async">  <span>GitHub</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/jupyter/jupyter-original.svg" alt="Jupyter" loading="lazy" decoding="async"> <span>Jupyter</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg" alt="VSCode" loading="lazy" decoding="async">  <span>VS Code</span></div>
            <div class="tech-pill"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bitbucket/bitbucket-original.svg" alt="Bitbucket" loading="lazy" decoding="async"><span>Bitbucket</span></div>
            <div class="tech-pill"><img src="https://cdn.worldvectorlogo.com/logos/seaborn-1.svg" alt="Seaborn" loading="lazy" decoding="async"> <span>Seaborn</span></div>
            <!-- Duplicate -->
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/javascript/javascript-original.svg" alt="" loading="lazy" decoding="async"><span>JavaScript</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/cplusplus/cplusplus-original.svg" alt="" loading="lazy" decoding="async"><span>C++</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/postgresql/postgresql-original.svg" alt="" loading="lazy" decoding="async"><span>PostgreSQL</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/mysql/mysql-original.svg" alt="" loading="lazy" decoding="async"><span>MySQL</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/docker/docker-original.svg" alt="" loading="lazy" decoding="async"><span>Docker</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/git/git-original.svg" alt="" loading="lazy" decoding="async"><span>Git</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/github/github-original.svg" alt="" loading="lazy" decoding="async"><span>GitHub</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/jupyter/jupyter-original.svg" alt="" loading="lazy" decoding="async"><span>Jupyter</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/vscode/vscode-original.svg" alt="" loading="lazy" decoding="async"><span>VS Code</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/bitbucket/bitbucket-original.svg" alt="" loading="lazy" decoding="async"><span>Bitbucket</span></div>
            <div class="tech-pill" aria-hidden="true"><img src="https://cdn.worldvectorlogo.com/logos/seaborn-1.svg" alt="" loading="lazy" decoding="async"><span>Seaborn</span></div>
          </div>
        </div>

      </div>
    </section>



    <!-- SIDE PROJECTS -->
    <section class="section reveal">
      <h2 class="section-kicker">Side Projects</h2>
      <p class="section-sub">Explorations that begin as MVPs and move toward production-ready products.</p>

      <div class="proj-list">
        <a href="/sideprojects/snake-minimalist-game/" class="proj-item" data-hover>
          <span class="proj-num">01</span>
          <div class="proj-content">
            <h3 class="proj-title">Snake Minimalist Game</h3>
