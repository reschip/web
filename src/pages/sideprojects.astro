---
import Layout from '../layouts/Layout.astro';
const playStoreUrl = "https://play.google.com/store/apps/details?id=com.vlufire.snakein";
---

<Layout
  title="Side Projects"
  description="Explore side projects by Andrés Cruz Chipol."
  showCanvas={false}
>
  <div class="lab">

    <nav class="breadcrumb">
      <a href="/" class="bc-link">← andreschipol.com</a>
      <span class="lab-meta">01 project</span>
    </nav>

    <header class="lab-title">
      <h1>Side Projects</h1>
    </header>

    <!-- THE card -->
    <div class="feature-card" id="feature-card">

      <!-- Dark editorial top -->
      <div class="card-hero">
        <div class="pixel-grid" aria-hidden="true"></div>
        <span class="bg-num" aria-hidden="true">01</span>

        <img src="/snake-icon.webp" alt="" class="hero-icon" aria-hidden="true" />

        <div class="hero-text">
          <span class="hero-eyebrow">Mobile · Flutter · Android</span>
          <h2 class="hero-title">Snake<br/><em>Minimalist</em><br/>Game</h2>
        </div>

        <span class="hero-badge">
          <span class="live-dot"></span> Live on Google Play
        </span>
      </div>

      <!-- Light content bottom -->
      <div class="card-body">
        <p class="card-desc">
          A clean reinterpretation of the classic Snake game. No distractions,
          no intrusive ads — just pure, focused gameplay with intuitive touch controls
          and a golden apple power-up built entirely in Flutter.
        </p>

        <div class="card-actions">
          <a
            href={playStoreUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-play"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15">
              <path d="M3.18 23.76A2.4 2.4 0 0 1 2 21.6V2.4A2.4 2.4 0 0 1 3.18.24L14.4 12 3.18 23.76zm2.64-1.02L19.2 14.4l-2.88-2.88-10.5 11.22zm14.16-8.34A2.37 2.37 0 0 1 21 12a2.37 2.37 0 0 1-1.02 1.98L17.52 15 14.4 12l3.12-3 2.46 1.38zM5.82 1.26 16.32 9.6 13.44 12.48 2.82 1.26z"/>
            </svg>
            Google Play Store
          </a>

          <a href="/sideprojects/snake-minimalist-game/" class="btn-details">
            View project →
          </a>
        </div>
      </div>

    </div>

    <div class="next-slot">
      <span>02</span>
      <span class="next-text">Next project in the works...</span>
    </div>

  </div>
</Layout>

<script>
  const card = document.getElementById('feature-card');
  if (card) {
    card.addEventListener('mousemove', (e) => {
      const r = card.getBoundingClientRect();
      const dx = ((e.clientX - r.left) / r.width  - .5) * 2;
      const dy = ((e.clientY - r.top)  / r.height - .5) * 2;
      card.style.transform = `perspective(1000px) rotateX(${-dy * 3}deg) rotateY(${dx * 5}deg)`;
    });
    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform .5s ease';
      card.style.transform  = 'none';
      setTimeout(() => card.style.transition = '', 500);
    });
    card.addEventListener('mouseenter', () => card.style.transition = 'transform .1s ease');
  }
</script>

<style>
  .lab {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem 2rem 5rem;
    font-family: 'Inter', sans-serif;
  }

  /* Top nav */
  .breadcrumb {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .bc-link {
    font-size: .75rem;
    color: var(--sage);
    text-decoration: none;
    transition: opacity .2s;
  }
  .bc-link:hover { opacity: .7; }
  .lab-meta {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--dust);
    border: 1px solid var(--rule);
    padding: .2rem .6rem;
    border-radius: 99px;
  }

  /* Section title */
  .lab-title {
    margin-bottom: 1.5rem;
  }
  .lab-title h1 {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.04em;
  }

  /* ══════════════════════════════════
     FEATURE CARD
  ══════════════════════════════════ */
  .feature-card {
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid var(--rule);
    box-shadow: 0 4px 24px rgba(0,0,0,.06);
    will-change: transform;
    transition: box-shadow .3s;
    margin-bottom: .75rem;
  }

  .feature-card:hover {
    box-shadow: 0 16px 56px rgba(0,0,0,.12);
  }

  /* ── Dark hero zone ── */
  .card-hero {
    position: relative;
    background: #0f1a14;
    padding: 2.5rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    overflow: hidden;
    min-height: 280px;
  }

  /* Pixel grid bg */
  .pixel-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px);
    background-size: 28px 28px;
    pointer-events: none;
  }

  /* Big background number */
  .bg-num {
    position: absolute;
    right: -0.05em;
    bottom: -0.15em;
    font-family: 'Outfit', sans-serif;
    font-size: clamp(8rem, 22vw, 14rem);
    font-weight: 900;
    color: rgba(255,255,255,.04);
    line-height: 1;
    letter-spacing: -0.06em;
    pointer-events: none;
    user-select: none;
  }

  /* App icon */
  .hero-icon {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    border: 2px solid rgba(255,255,255,.12);
    box-shadow: 0 4px 20px rgba(0,0,0,.4);
    position: relative;
    z-index: 1;
  }

  /* Title block */
  .hero-text {
    position: relative;
    z-index: 1;
    flex: 1;
  }

  .hero-eyebrow {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: rgba(255,255,255,.4);
    display: block;
    margin-bottom: .6rem;
  }

  .hero-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2.2rem, 6vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.04em;
    line-height: .95;
  }

  .hero-title em {
    font-style: normal;
    color: #7fcba4; /* sage on dark */
  }

  /* Live badge */
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: #7fcba4;
    background: rgba(127, 203, 164, .12);
    border: 1px solid rgba(127, 203, 164, .3);
    padding: .3rem .75rem;
    border-radius: 99px;
    align-self: flex-start;
    position: relative;
    z-index: 1;
  }

  .live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #7fcba4;
    animation: live-pulse 1.8s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes live-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .3; transform: scale(.7); }
  }

  /* ── Light content zone ── */
  .card-body {
    background: #fff;
    padding: 1.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .card-desc {
    font-size: .88rem;
    color: var(--ink-2);
    line-height: 1.7;
    flex: 1;
    min-width: 220px;
  }

  /* Actions */
  .card-actions {
    display: flex;
    align-items: center;
    gap: .75rem;
    flex-shrink: 0;
  }

  .btn-play {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .55rem 1rem;
    background: #0f1a14;
    color: #fff;
    border-radius: 10px;
    text-decoration: none;
    font-size: .78rem;
    font-weight: 600;
    transition: background .2s, transform .15s;
    white-space: nowrap;
  }

  .btn-play:hover {
    background: #7fcba4;
    color: #0f1a14;
    transform: translateY(-1px);
  }

  .btn-details {
    font-size: .78rem;
    color: var(--sage);
    font-weight: 600;
    text-decoration: none;
    transition: opacity .2s;
    white-space: nowrap;
  }
  .btn-details:hover { opacity: .7; }

  /* Next slot */
  .next-slot {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: .9rem 1.25rem;
    border: 1px dashed var(--rule);
    border-radius: 14px;
    opacity: .35;
  }

  .next-slot span:first-child {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 800;
    color: var(--dust);
    letter-spacing: -0.03em;
  }

  .next-text {
    font-size: .72rem;
    color: var(--dust);
    font-style: italic;
    flex: 1;
  }

  @media (max-width: 600px) {
    .lab { padding: 2rem 1.25rem 4rem; }
    .card-body { flex-direction: column; align-items: flex-start; }
    .card-actions { width: 100%; }
  }
</style>
