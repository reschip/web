---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Snake Minimalist Game"
  description="Development details of the Snake Minimalist Game mobile app for Google Play Store."
  showCanvas={false}
>
  <div class="inner-page">

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/" class="bc-link">andreschipol.com</a>
      <span class="bc-sep">/</span>
      <a href="/sideprojects" class="bc-link">Side Projects</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">Snake Minimalist Game</span>
    </nav>

    <!-- Header -->
    <header class="inner-header">
      <p class="inner-eyebrow">Side Project · 01</p>
      <h1 class="inner-title">Snake Minimalist <span class="title-accent">Game</span></h1>
      <p class="inner-sub">
        Personal mobile game inspired by the classic Snake — designed with a minimalist
        aesthetic and accessible mechanics for quick, satisfying sessions.
      </p>
      <div class="header-tags">
        <span class="tag">Flutter</span>
        <span class="tag">Dart</span>
        <span class="tag">Mobile</span>
        <span class="tag">Android</span>
        <span class="tag tag--status">In Development</span>
      </div>
    </header>

    <div class="doc-body">

      <section class="doc-section">
        <h2 class="doc-heading">Project goal</h2>
        <p>
          Build a clean, responsive experience with intuitive touch controls, soft visual
          effects, and support for multiple screen sizes on Android.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading">Features in progress</h2>
        <ul class="doc-list">
          <li>Minimal gameplay loop featuring a <strong>golden apple power-up</strong> that provides a temporary speed boost.</li>
          <li>Single in-memory score save to validate the flow before persistent storage.</li>
          <li>Minimalist interface focused on clarity and fast iterations.</li>
        </ul>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading">Tech stack</h2>
        <p>
          Built entirely with <strong>Flutter</strong> to keep the experience consistent across Android
          devices. No external repositories are available yet — all experiments live in a
          private local workspace.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading">Legal documentation</h2>
        <p style="margin-bottom: 1rem;">
          Review the terms and privacy materials prepared for the Google Play Store submission.
        </p>
        <div class="doc-links">
          <a href="/sideprojects/snake-minimalist-game/terms-and-conditions" class="doc-link">
            <span>Terms &amp; Conditions</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/sideprojects/snake-minimalist-game/privacy-policy" class="doc-link">
            <span>Privacy Policy</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </section>

    </div>
  </div>
</Layout>

<style>
  .inner-page {
    max-width: 740px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
    font-family: 'Inter', sans-serif;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .72rem;
    color: var(--dust);
    margin-bottom: 2.5rem;
  }
  .bc-link { color: var(--sage); text-decoration: none; transition: opacity .2s; }
  .bc-link:hover { opacity: .7; }
  .bc-sep { color: var(--rule); }
  .bc-current { color: var(--dust); }

  .inner-header { margin-bottom: 3rem; }

  .inner-eyebrow {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--dust);
    margin-bottom: .75rem;
  }

  .inner-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 1rem;
  }

  .title-accent { color: var(--sage); }

  .inner-sub {
    font-size: .95rem;
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 520px;
    margin-bottom: 1.25rem;
  }

  .header-tags { display: flex; gap: .4rem; flex-wrap: wrap; }

  .tag {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .2rem .55rem;
    border-radius: 99px;
    background: var(--cream-2);
    color: var(--dust);
    border: 1px solid var(--rule);
  }

  .tag--status {
    background: #dcf5eb;
    color: var(--sage);
    border-color: #b8e8d2;
  }

  /* Doc body */
  .doc-body { display: flex; flex-direction: column; }

  .doc-section {
    padding: 2rem 0;
    border-top: 1px solid var(--rule);
    font-size: .95rem;
    color: var(--ink-2);
    line-height: 1.75;
  }

  .doc-section:last-child { border-bottom: 1px solid var(--rule); }

  .doc-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin-bottom: .75rem;
  }

  .doc-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }

  .doc-list li {
    padding-left: 1rem;
    position: relative;
  }

  .doc-list li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--sage);
    font-weight: 600;
  }

  .doc-links {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
  }

  .doc-link {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    padding: .55rem 1rem;
    border: 1px solid var(--rule);
    border-radius: 8px;
    background: #fff;
    color: var(--ink-2);
    text-decoration: none;
    font-size: .82rem;
    font-weight: 500;
    transition: border-color .2s, color .2s, background .2s;
  }

  .doc-link svg { width: 14px; height: 14px; transition: transform .2s; }

  .doc-link:hover {
    border-color: var(--sage);
    color: var(--sage);
    background: #f5fbf8;
  }

  .doc-link:hover svg { transform: translateX(3px); }
</style>
