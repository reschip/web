---
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="Terms & Conditions — Snake Minimalist Game"
  description="Terms and conditions for Snake Minimalist Game published on Google Play Store."
  showCanvas={false}
>
  <div class="inner-page">

    <!-- Breadcrumb -->
    <nav class="breadcrumb">
      <a href="/" class="bc-link">andreschipol.com</a>
      <span class="bc-sep">/</span>
      <a href="/sideprojects" class="bc-link">Side Projects</a>
      <span class="bc-sep">/</span>
      <a href="/sideprojects/snake-minimalist-game/" class="bc-link">Snake Minimalist Game</a>
      <span class="bc-sep">/</span>
      <span class="bc-current">Terms &amp; Conditions</span>
    </nav>

    <!-- Header -->
    <header class="inner-header">
      <p class="inner-eyebrow">Legal · Snake Minimalist Game</p>
      <h1 class="inner-title">Terms &amp; Conditions</h1>
      <p class="inner-meta">Last updated: 22 October 2025</p>
      <p class="inner-sub">
        These terms govern the use of the mobile application <strong>Snake Minimalist Game</strong>
        (the "App"), developed by Andrés Cruz Chipol (the "Developer"). By downloading or using
        the App, you agree to these terms in full.
      </p>
    </header>

    <div class="doc-body">

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">01</span> Permitted use</h2>
        <p>
          The App is intended solely for personal and recreational use. Commercial use, unauthorized
          distribution, or modification is prohibited without the Developer's express permission.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">02</span> Privacy and data</h2>
        <p>
          Snake Minimalist Game does not request sensitive personal data. The game may collect
          anonymous usage data (such as scores or session metrics) to improve the experience. Data
          will not be shared with third parties without your explicit consent.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">03</span> User-generated content</h2>
        <p>
          Any content or feedback you voluntarily provide may be used by the Developer for
          improvements or promotional materials, while keeping your anonymity.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">04</span> Intellectual property</h2>
        <p>
          All elements of the App (including code, graphics, and sounds) are owned by the Developer.
          You do not acquire ownership rights by downloading or using the App.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">05</span> Limitation of liability</h2>
        <p>
          The App is provided "as is" without express or implied warranties. The Developer is not
          responsible for direct or indirect damages that may arise from using the App.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">06</span> Changes to the terms</h2>
        <p>
          The Developer may update these terms at any time. Changes will be communicated through
          the App listing on Google Play Store or within the App.
        </p>
      </section>

      <section class="doc-section">
        <h2 class="doc-heading"><span class="doc-num">07</span> Contact</h2>
        <p>
          For questions about these terms, email
          <a class="doc-mailto" href="mailto:andres@andreschipol.com">andres@andreschipol.com</a>.
        </p>
      </section>

    </div>

    <footer class="doc-footer">
      <p>Thank you for playing Snake Minimalist Game.</p>
      <a href="/sideprojects/snake-minimalist-game/" class="doc-back">← Back to project</a>
    </footer>

  </div>
</Layout>

<style>
  .inner-page {
    max-width: 740px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem;
    font-family: 'Inter', sans-serif;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: .5rem;
    font-size: .72rem;
    color: var(--dust);
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }
  .bc-link { color: var(--sage); text-decoration: none; transition: opacity .2s; }
  .bc-link:hover { opacity: .7; }
  .bc-sep { color: var(--rule); }
  .bc-current { color: var(--dust); }

  .inner-header { margin-bottom: 3rem; }

  .inner-eyebrow {
    font-size: .62rem;
    font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--dust);
    margin-bottom: .75rem;
  }

  .inner-title {
    font-family: 'Outfit', sans-serif;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 900;
    color: var(--ink);
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: .5rem;
  }

  .inner-meta {
    font-size: .75rem;
    color: var(--dust);
    margin-bottom: .75rem;
  }

  .inner-sub {
    font-size: .95rem;
    color: var(--ink-2);
    line-height: 1.75;
    max-width: 520px;
  }

  .doc-body { display: flex; flex-direction: column; }

  .doc-section {
    padding: 1.75rem 0;
    border-top: 1px solid var(--rule);
    font-size: .92rem;
    color: var(--ink-2);
    line-height: 1.8;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .doc-section:last-child { border-bottom: 1px solid var(--rule); }

  .doc-heading {
    font-family: 'Outfit', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: .65rem;
  }

  .doc-num {
    font-size: .6rem;
    font-weight: 800;
    letter-spacing: .1em;
    background: var(--cream-2);
    color: var(--dust);
    padding: .2rem .45rem;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }

  .doc-mailto {
    color: var(--sage);
    text-decoration: none;
    border-bottom: 1px solid var(--sage-lt);
    transition: opacity .2s;
  }
  .doc-mailto:hover { opacity: .7; }

  .doc-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: .82rem;
    color: var(--dust);
  }

  .doc-back {
    color: var(--sage);
    text-decoration: none;
    font-size: .8rem;
    transition: opacity .2s;
  }
  .doc-back:hover { opacity: .7; }
</style>
